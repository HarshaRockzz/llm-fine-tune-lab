# ── Model ─────────────────────────────────────────────────────────────────────
MODEL_NAME=meta-llama/Meta-Llama-3-8B
ADAPTER_DIR=outputs/adapters

# ── API Server ────────────────────────────────────────────────────────────────
PORT=8000
TENSOR_PARALLEL_SIZE=1
GPU_MEMORY_UTIL=0.90
MAX_MODEL_LEN=4096
QUANTIZATION=                          # leave empty for bfloat16, or set awq/gptq
ALLOWED_ORIGINS=*

# ── HuggingFace ───────────────────────────────────────────────────────────────
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_HOME=~/.cache/huggingface

# ── Weights & Biases ──────────────────────────────────────────────────────────
WANDB_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WANDB_PROJECT=llm-fine-tune-lab
WANDB_ENTITY=

# ── OpenRouter (LLM-as-Judge + Playground + Embeddings) ─────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct:free
OPENROUTER_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
LLM_PROVIDER=openrouter
EMBEDDING_PROVIDER=openrouter

# ── Qdrant (semantic experiment search) ──────────────────────────────────────
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# ── Streamlit ─────────────────────────────────────────────────────────────────
VLLM_API_URL=http://localhost:8000      # set to empty string for demo mode

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
GPU_COUNT=1
